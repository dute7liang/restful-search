<idea-plugin url="https://plugins.jetbrains.com" allow-bundled-update="true">
    <id>com.dute7liang.restful.search</id>
    <name>RestfulSearch</name>
    <version>1.0.0</version>
    <vendor email="383200134@qq.com" url="https://github.com/dute7liang/restful-search">dute7liang</vendor>

    <description><![CDATA[
  <h3>RestfulSearch</h3>
  <p>Search and navigate REST endpoints in IntelliJ IDEA.</p>
  <ul>
   <li>Find REST services by URL or mapping path.</li>
   <li>Jump directly to endpoint declarations from the search popup.</li>
   <li>Use Ctrl + \ or Ctrl + Alt + N to open the REST service search popup.</li>
   <li>Supports Spring MVC, Spring Boot, JAX-RS, Java, and Kotlin.</li>
 </ul>
    ]]></description>

    <!-- please see http://www.jetbrains.org/intellij/sdk/docs/basics/getting_started/build_number_ranges.html for description -->
    <idea-version since-build="261.*"/>

    <!-- please see http://www.jetbrains.org/intellij/sdk/docs/basics/getting_started/plugin_compatibility.html
         on how to target different products -->
    <!-- uncomment to enable plugin in all products
    <depends>com.intellij.modules.lang</depends>
    -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>
    <depends>com.intellij.properties</depends>
    <depends>org.jetbrains.plugins.yaml</depends>
    <depends>org.jetbrains.kotlin</depends>


    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="com.dute7liang.restful.navigation.action.GotoRequestMappingConfiguration"/>
        <tipAndTrick feature-id="navigation.popup.service" file="GotoService.html"/>
    </extensions>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>


    <actions>
        <!-- url 导航 -->
        <action id="Toolkit.GotoService" class="com.dute7liang.restful.navigation.action.GotoRequestMappingAction"
                text="_Service" description="Go to Service"
                icon="AllIcons.Actions.Search">
            <add-to-group group-id="GoToTargetEx" anchor="first"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl BACK_SLASH"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt N"/>
        </action>

        <!--code gen-->
