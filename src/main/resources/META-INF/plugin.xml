                      description="SpringBootAppRunnerAction">
                  &lt;!&ndash;<add-to-group group-id="RunnerActions" anchor="after" relative-to-action=""/>&ndash;&gt;
                  <add-to-group group-id="NewGroup" anchor="after" relative-to-action="NewDir"/>
              </action>
              -->

    </actions>
</idea-plugin>
